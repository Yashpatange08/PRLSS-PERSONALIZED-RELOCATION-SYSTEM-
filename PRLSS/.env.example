# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-this-in-production-50chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Google Maps API Key ───────────────────────────────────────────────────────
# Get from https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=AIzaSy_paste_your_key_here

# ── Same key for React frontend ───────────────────────────────────────────────
VITE_GOOGLE_MAPS_KEY=AIzaSy_paste_your_key_here

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
DATABASE_URL=postgres://prlss_user:prlss_pass@localhost:5432/prlss_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
